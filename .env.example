# Canonical public origin. Do not include a trailing path.
NEXT_PUBLIC_SITE_URL=https://michigan-outdoors-now.vercel.app

# Safe default: previews and unapproved deployments stay out of search.
# Vercel production builds are enabled automatically; use true only for an
# approved production build outside Vercel.
NEXT_PUBLIC_ALLOW_INDEXING=false

# Emergency opt-out for an approved production deployment.
NEXT_PUBLIC_DISABLE_INDEXING=false
